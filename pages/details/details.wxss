/* Container for the whole page */
.container {
  padding: 30rpx 20rpx;
  background-color: #fff;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
}

/* Back button */
.back-btn {
  position: fixed;
  top: 30rpx;
  left: 20rpx;
  background-color: transparent;
  border: none;
  font-size: 28rpx;
  color: #333;
  cursor: pointer;
  font-weight: 600;
  z-index: 10;
  user-select: none;
}

/* Product image */
.product-image {
  width: 320rpx;
  height: 320rpx;
  border-radius: 16rpx;
  object-fit: cover;
  margin-top: 100rpx;
  margin-bottom: 30rpx;
}

/* Product name */
.product-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #222;
  margin-bottom: 12rpx;
  text-align: center;
  word-break: break-word;
}

/* Product price */
.product-price {
  font-size: 32rpx;
  font-weight: 600;
  color: #e03e2f;
  margin-bottom: 8rpx;
}

/* Product category */
.product-category {
  font-size: 24rpx;
  color: #888;
  margin-bottom: 40rpx;
  text-align: center;
}

/* Quantity control */
.quantity-control {
  width: 300rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  border: 1rpx solid #ddd;
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 30rpx;
  background-color: #f9f9f9;
}

/* - and + buttons */
.qty-btn {
  width: 64rpx;
  height: 64rpx;
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  background-color: #fff;
  border: none;
  display: flex;
  justify-content: center;
  align-items: center;
  user-select: none;
}

.qty-btn:active {
  background-color: #e03e2f;
  color: #fff;
}

/* Quantity display */
.qty-display {
  width: 160rpx;
  height: 64rpx;
  background-color: #f7f7f7;
  font-size: 32rpx;
  font-weight: 600;
  color: #222;
  line-height: 64rpx;
  text-align: center;
  border-left: 1rpx solid #ddd;
  border-right: 1rpx solid #ddd;
  user-select: none;
}

/* Add to Cart container */
.add-to-cart-inline {
  width: 100%;
  display: flex;
  justify-content: center;
  margin-bottom: 50rpx;
}

/* Add to Cart button */
.add-to-cart-btn {
  background-color: #e03e2f;
  color: white;
  border-radius: 12rpx;
  height: 64rpx;
  width: 90%;
  font-size: 32rpx;
  font-weight: 700;
  border: none;
  cursor: pointer;
  transition: background-color 0.3s ease;
  user-select: none;
}

.add-to-cart-btn:active {
  background-color: #b93229;
}
