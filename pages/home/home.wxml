<!-- pages/home/home.wxml -->
<view class="container">

  <!-- 🔍 Search Bar -->
  <view class="search-bar">
    <input class="search-input" placeholder="Search products..." value="{{searchQuery}}" bindinput="onSearchInput" />
    <button class="search-button" bindtap="onSearch">Search</button>
    <button class="cancel-button" wx:if="{{isSearching}}" bindtap="onCancelSearch">Cancel</button>
  </view>

  <!-- Search Results View -->
  <view wx:if="{{isSearching}}">
    <view class="section-title">Search Results for "{{searchQuery}}"</view>
    <view class="search-results-count">{{searchResults.length}} results found</view>
    
    <view class="product-grid">
      <block wx:for="{{searchResults}}" wx:key="id">
        <view class="product-card-grid" bindtap="onProductTap" data-id="{{item.id}}">
          <image src="{{item.image}}" class="product-image-grid" mode="aspectFill" />
          <view class="product-info">
            <text class="product-name">{{item.name}}</text>
            <text class="product-price">¥{{item.price}}</text>
          </view>
        </view>
      </block>
    </view>
    
    <view wx:if="{{searchResults.length === 0}}" class="no-results">
      <text>No products found for "{{searchQuery}}"</text>
    </view>
  </view>

  <!-- 🖼 Banner Swiper -->
  <swiper class="banner-swiper" indicator-dots autoplay interval="4000" duration="500">
    <block wx:for="{{banners}}" wx:key="index">
      <swiper-item>
        <image src="{{item.image}}" class="banner-image" mode="aspectFill" />
      </swiper-item>
    </block>
  </swiper>

  <!-- 🧭 Categories -->
  <view class="categories">
    <block wx:for="{{categories}}" wx:key="id">
      <view class="category-item" bindtap="onCategoryTap" data-id="{{item.id}}">
        <image src="{{item.icon}}" class="category-icon" mode="aspectFit" />
        <text class="category-text">{{item.name}}</text>
      </view>
    </block>
  </view>

  <!-- ⭐ Featured Products (horizontal scroll) -->
  <view class="section-title">Featured Products</view>
  <scroll-view class="product-list" scroll-x="true" show-scrollbar="false">
    <block wx:for="{{featuredProducts}}" wx:key="id">
      <view class="product-card-featured" bindtap="onProductTap" data-id="{{item.id}}">
        <image src="{{item.image}}" class="product-image-featured" mode="aspectFill" />
        <view class="product-info">
          <text class="product-name">{{item.name}}</text>
          <text class="product-price">¥{{item.price}}</text>
        </view>
      </view>
    </block>
  </scroll-view>

  <!-- 📋 Grid of Selected Category (2 per row vertical) -->
  <view class="section-title-categories">{{selectedCategoryName}} Products</view>
  <view class="product-grid">
    <block wx:for="{{filteredProducts}}" wx:key="id">
      <view class="product-card-grid" bindtap="onProductTap" data-id="{{item.id}}">
        <image src="{{item.image}}" class="product-image-grid" mode="aspectFill" />
        <view class="product-info">
          <text class="product-name">{{item.name}}</text>
          <text class="product-price">¥{{item.price}}</text>
        </view>
      </view>
    </block>
  </view>

    

</view>
