<!--pages/cart/cart.wxml-->
<view class="container">
  <view class="header">
    <text class="title">My Cart</text>
  </view>

  <block wx:if="{{cart.length === 0}}">
    <text>Your cart is empty.</text>
  </block>

  <block wx:else>
    <block wx:for="{{cart}}" wx:key="id">
      <view class="cart-item">
        <image src="{{item.image}}" class="cart-image" mode="aspectFill" />
        <view class="cart-info">
          <text class="cart-name">{{item.name}}</text>
          <text>Price: ¥{{item.price}}</text>
          <text>Quantity: {{item.quantity}}</text>
          <button data-id="{{item.id}}" bindtap="removeFromCart">Remove</button>
        </view>
      </view>
    </block>

    <view class="cart-summary">
      <text>Total: ¥{{totalPrice}}</text>
    </view>
  </block>
  <button class="pay-btn" bindtap="placeOrder" wx:if="{{cart.length > 0}}">Proceed to Payment</button>

</view>
