/* pages/cart/cart.wxss */
.container {
  padding: 20rpx;
}

.header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.title {
  font-size: 32rpx;
  font-weight: bold;
}

.cart-item {
  display: flex;
  margin-bottom: 20rpx;
  background: #fafafa;
  border-radius: 12rpx;
  padding: 10rpx;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.1);
}

.cart-image {
  width: 100rpx;
  height: 100rpx;
  border-radius: 10rpx;
}

.cart-info {
  flex: 1;
  margin-left: 20rpx;
}

.cart-name {
  font-weight: 600;
  font-size: 28rpx;
  margin-bottom: 10rpx;
}

.cart-summary {
  font-size: 30rpx;
  font-weight: bold;
  text-align: right;
  margin-top: 20rpx;
}
