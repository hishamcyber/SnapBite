/* pages/orders/orders.wxss */
.container {
  padding: 20rpx;
}

.header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.title {
  font-size: 32rpx;
  font-weight: bold;
}

.order-date {
  font-size: 28rpx;
  margin-bottom: 20rpx;
}

.order-item {
  display: flex;
  margin-bottom: 20rpx;
  background: #fafafa;
  border-radius: 12rpx;
  padding: 10rpx;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.1);
}

.order-image {
  width: 100rpx;
  height: 100rpx;
  border-radius: 10rpx;
}

.order-info {
  flex: 1;
  margin-left: 20rpx;
}

.order-info text {
  display: block;
  font-size: 28rpx;
  margin-bottom: 6rpx;
}

.order-total {
  font-size: 30rpx;
  font-weight: bold;
  text-align: right;
  margin-top: 20rpx;
}
